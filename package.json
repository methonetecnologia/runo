    "@opentui/solid": "^0.1.84",
    "babel-preset-solid": "^1.9.10",
    "shiki": "^4.0.0",
    "solid-js": "^1.9.11",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.9",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-solid": "^0.14.5",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.56.1"
