{
  "name": "runo",
  "version": "0.1.0",
  "description": "Terminal IDE inspired by VS Code, built on OpenTUI and SolidJS",
  "main": "src/index.tsx",
  "scripts": {
    "dev": "bun --conditions=browser --preload ./preload.ts src/index.tsx",
    "build": "bun run build.ts",
    "build:linux-x64": "bun run build.ts --target=bun-linux-x64 --outfile=runo-linux-x64",
    "build:linux-arm64": "bun run build.ts --target=bun-linux-arm64 --outfile=runo-linux-arm64",
    "build:darwin-x64": "bun run build.ts --target=bun-darwin-x64 --outfile=runo-darwin-x64",
    "build:darwin-arm64": "bun run build.ts --target=bun-darwin-arm64 --outfile=runo-darwin-arm64",
    "build:windows-x64": "bun run build.ts --target=bun-windows-x64 --outfile=runo-windows-x64",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}'",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "ci": "bun run lint && bun run format:check && bun test"
  },
  "keywords": [
    "terminal",
    "ide",
    "tui",
    "editor",
    "vscode",
    "opentui",
    "solidjs"
  ],
  "author": "Methone Tecnologia",
  "license": "CC-BY-NC-4.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/methonetecnologia/runo"
  },
  "type": "module",
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@opentui/core": "^0.1.84",
    "@opentui/solid": "^0.1.84",
    "babel-preset-solid": "^1.9.10",
    "pino": "^10.3.1",
    "shiki": "^4.0.0",
    "solid-js": "^1.9.11",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.9",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-solid": "^0.14.5",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.56.1"
  }
}
